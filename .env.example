## Server
PORT=3000

## External data providers
COINGECKO_API_KEY=your_coingecko_api_key

## AI provider (DeepSeek)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat
# Optional: AI chat reply style (0–1.2, default ~0.62)
# CHAT_TEMPERATURE=0.62

## Owner-only access control (AI Chat)
# Set these on Render as Environment Variables
# Single user mode (default true): bypass owner login requirements.
# SINGLE_USER_MODE=true
OWNER_USERNAME=admin
OWNER_PASSWORD=change-me

# Optional: token TTL in milliseconds (default: 1800000 = 30 minutes)
AUTH_TOKEN_TTL_MS=1800000

## Demo trading (Binance Futures Testnet)
BINANCE_TESTNET_BASE_URL=https://testnet.binancefuture.com
BINANCE_TESTNET_API_KEY=your_binance_testnet_api_key
BINANCE_TESTNET_API_SECRET=your_binance_testnet_api_secret
BINANCE_TESTNET_TRADING_ENABLED=false
DEMO_DEFAULT_USDT_NOTIONAL=20

# Demo trade decision (DeepSeek-first; EA-style rules off by default)
# DEMO_AGGRESSIVE_ON_WAIT=false
# DEMO_RELAXED_AI_PROMPT=false
# DEMO_RULE_FALLBACK_ON_DEEPSEEK_ERROR=false
# DEMO_TRADE_AI_TEMPERATURE=0.42
# DEMO_AUTO_MIN_CONFIDENCE=0.45
# DEMO_AUTO_TRADING_INTERVAL_MS=120000
# DEMO_HISTORY_PROFILE_DAYS=365
# DEMO_SHORT_TERM_BUY_EXHAUST_MULT=1.0
# DEMO_SHORT_TERM_SELL_EXHAUST_MULT=1.0
# DEMO_ADAPTIVE_EXIT_ENABLED=true
# DEMO_ADAPTIVE_HARD_SL_PCT=1.2
# DEMO_ADAPTIVE_SOFT_SL_PCT=0.6
# DEMO_ADAPTIVE_LOCK_TRIGGER_PCT=0.8
# DEMO_ADAPTIVE_LOCK_RETRACE_PCT=0.55

## MT4 bridge (MVP: XAUUSD only)
# Single-user: allow Gold Lab / History Data without owner login (set false to require X-MT4-Key or login)
# MT4_GOLD_PUBLIC_READ=true
# MT4_SHARED_SECRET=change-me
# MT4_MIN_CALL_INTERVAL_MS=120000
# Anti-scalping: min time between OPEN signals when flat (ms), default 12m
# MT4_MIN_MS_BETWEEN_NEW_ENTRIES=720000
# Widen stops: SL distance >= max(floor, avgM5Range * mult)
# MT4_MIN_SL_PRICE_FLOOR=6.0
# MT4_MIN_SL_RANGE_MULT=2.2
# MT4_DEFAULT_TP_RR=1.8
# Block OPEN_* if model confidence below threshold
# MT4_MIN_ENTRY_CONFIDENCE=0.48
# Block new entries when D1 vs M5 trend conflict is strong
# MT4_CONFLICT_ALIGNMENT_SOFT_BLOCK=true
# MT4_CONFLICT_ALIGNMENT_STRENGTH=0.28
# Python SMC must exceed this confidence to override DeepSeek (default stricter)
# MT4_PYTHON_SMC_PRIORITY_MIN_CONF=0.78
# MT4_XAUUSD_MAX_SPREAD_POINTS=45
# Soft-block OPEN_BUY when D1+M5 strongly bearish (and mirror for sells); skipped if positions open
# MT4_CONTRA_TREND_SOFT_BLOCK=true
# Strength threshold 0.15–0.85 (higher = stricter trend filter)
# MT4_CONTRA_TREND_STRENGTH=0.35
# MT4_GOLD_HISTORY_MAX_ROWS=1500000
# MT4_REQUIRE_BOOTSTRAP=true
# MT4_PYTHON_SMC_ENABLED=true
# MT4_PYTHON_SMC_PRIORITY=true
# MT4_AI_FULL_CONTROL=true
# MT4_PYTHON_BIN=python
# MT4_PYTHON_SMC_TIMEOUT_MS=4500
# MT4_GLOBAL_HISTORY_MODE=true
# MT4_TOKEN_SAVER_MODE=true
# MT4_REUSE_DECISION_SAME_BAR=true
# MT4_MIN_CALL_INTERVAL_OPEN_MS=10000
# MT4_DEEPSEEK_CANDLES_MAX=60
# MT4_TOKEN_SAVER_MAX_SPREAD_POINTS=35
# MT4_TOKEN_SAVER_IMPULSE_MIN=0.00035
# MT4_TOKEN_SAVER_AVGRET_MIN=0.00022
# MT4_PERSISTENCE_MODE=disk_file
# MT4_POSTGRES_ENABLED=true
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# PG_SSL_REQUIRE=true

