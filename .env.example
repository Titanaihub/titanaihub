## Server
PORT=3000

## External data providers
COINGECKO_API_KEY=your_coingecko_api_key

## AI provider (DeepSeek)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat
# Optional: AI chat reply style (0–1.2, default ~0.62)
# CHAT_TEMPERATURE=0.62

## Owner-only access control (AI Chat)
# Set these on Render as Environment Variables
OWNER_USERNAME=admin
OWNER_PASSWORD=change-me

# Optional: token TTL in milliseconds (default: 1800000 = 30 minutes)
AUTH_TOKEN_TTL_MS=1800000

## Demo trading (Binance Futures Testnet)
BINANCE_TESTNET_BASE_URL=https://testnet.binancefuture.com
BINANCE_TESTNET_API_KEY=your_binance_testnet_api_key
BINANCE_TESTNET_API_SECRET=your_binance_testnet_api_secret
BINANCE_TESTNET_TRADING_ENABLED=false
DEMO_DEFAULT_USDT_NOTIONAL=20

# Demo trade decision (DeepSeek-first; EA-style rules off by default)
# DEMO_AGGRESSIVE_ON_WAIT=false
# DEMO_RELAXED_AI_PROMPT=false
# DEMO_RULE_FALLBACK_ON_DEEPSEEK_ERROR=false
# DEMO_TRADE_AI_TEMPERATURE=0.42
# DEMO_AUTO_MIN_CONFIDENCE=0.45
# DEMO_AUTO_TRADING_INTERVAL_MS=120000
# DEMO_HISTORY_PROFILE_DAYS=365
# DEMO_SHORT_TERM_BUY_EXHAUST_MULT=1.0
# DEMO_SHORT_TERM_SELL_EXHAUST_MULT=1.0
# DEMO_ADAPTIVE_EXIT_ENABLED=true
# DEMO_ADAPTIVE_HARD_SL_PCT=1.2
# DEMO_ADAPTIVE_SOFT_SL_PCT=0.6
# DEMO_ADAPTIVE_LOCK_TRIGGER_PCT=0.8
# DEMO_ADAPTIVE_LOCK_RETRACE_PCT=0.55

## MT4 bridge (MVP: XAUUSD only)
# MT4_SHARED_SECRET=change-me
# MT4_MIN_CALL_INTERVAL_MS=30000
# MT4_XAUUSD_MAX_SPREAD_POINTS=45
# MT4_GOLD_HISTORY_MAX_ROWS=250000
# MT4_REQUIRE_BOOTSTRAP=true
# MT4_PYTHON_SMC_ENABLED=true
# MT4_PYTHON_SMC_PRIORITY=true
# MT4_PYTHON_BIN=python
# MT4_PYTHON_SMC_TIMEOUT_MS=4500

